rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Firestore native rules ensuring strict user-level isolation.
    // Cross-user reading is prohibited. 
    // To resolve usernames during sign-in, the application uses a secure server-side FastAPI endpoint running with administrative privileges.
    
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      // Allow creation during signup, validating that the incoming document matches the authenticated UID
      allow create: if request.auth != null && request.auth.uid == uid;
      
      // Subcollections are strictly locked to the resource owner
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
