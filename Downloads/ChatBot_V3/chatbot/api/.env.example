# Google Gemini API configuration
# Retrieve from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Custom Search Engine (CSE) configuration
# Retrieve from: https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=your_custom_search_engine_id_here
GOOGLE_CSE_KEY=your_custom_search_engine_api_key_here

# Firebase Storage Bucket configuration
# Example: chatbot-app.appspot.com (omit gs://)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
